{
  "name": "cloudflare-hono-waitlist-template",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "client": "bun --bun astro dev",
    "build:client": "bun --bun astro build",
    "preview": "bun --bun astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint 'src/**/*.{js,ts,tsx,astro}'",
    "worker": "wrangler dev",
    "dev": "concurrently \"bun run client\" \"bun run worker\"",
    "dryrun:staging": "bun run build:client && wrangler deploy --dry-run --env staging",
    "dryrun:prod": "bun run build:client && wrangler deploy --dry-run --env production",
    "deploy:staging": "bun run build:client && wrangler deploy --env staging",
    "deploy:prod": "bun run build:client && wrangler deploy --env production",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply cloudflare-hono-waitlist-template-local-db --local",
    "db:migrate:staging": "wrangler d1 migrations apply cloudflare-hono-waitlist-template-staging-db --remote --env staging",
    "create:test:db": "bun run ./scripts/create-test-db.ts",
    "destroy:test:db": "bun run ./scripts/destroy-test-db.ts",
    "test": "bun create:test:db && bun test && bun run destroy:test:db"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.7",
    "concurrently": "^10.0.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.29",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "wrangler": "^4.110.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260715.1",
    "@types/bun": "^1.3.14",
    "@typescript-eslint/parser": "^8.63.0",
    "daisyui": "^5.6.17",
    "drizzle-kit": "^0.31.10",
    "drizzle-seed": "^0.3.1",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^2.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0"
  }
}
